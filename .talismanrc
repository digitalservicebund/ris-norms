allowed_patterns:
  - uses:\ ([A-z0-9\-]+\/)*[A-z0-9\-]+@[a-fA-F0-9]{40}
  - https://github.com/jk1/Gradle-License-Report/blob/7cf695c38126b63ef9e907345adab84dfa92ea0e/src/main/resources/default-license-normalizer-bundle.json
  - https://github.com/digitalservicebund/ris-norms/commit/17778285381a674f1a2b742ed573b7d3d542ea24
  - cgr.dev/chainguard/jre@sha256:[a-fA-F0-9]{64}
  - github_app_private_key
  - GITOPS_NEURIS_APP_PRIVATE_KEY
  - "secrets: inherit"
  - "key: "
  - BUCKET_ACCESS_KEY_ID
  - BUCKET_SECRET_ACCESS_KEY
threshold: medium
version: "1.0"
scopeconfig:
  - scope: node
fileignoreconfig:
  - filename: Dockerfile
    checksum: 26a54a3f886b98449f76c7c4c89b706f3cc3054e4d71f19fe7b2bfe93f802f10
  - filename: docker-compose.yaml
    checksum: 252e8ac97929919d356866e02d9d9a0641d466cbe81e4555af54172b0c0bbdc2
  - filename: ldml-extension/fixtures/*.xml
    ignore_detectors: [filecontent]
  - filename: doc/adr/0009-renovate.md
    checksum: 8730330b81ae0ead8b42c4c1f22d4065305813c2112c5885bb29d04796aab268
  - filename: LegalDocML.de/*/fixtures/*/*.xml
    ignore_detectors: [filecontent]
  - filename: LegalDocML.de/*/schema-extension-fixtures/*/*.xml
    ignore_detectors: [filecontent]
  - filename: LegalDocML.de/*/fixtures/*.xml
    ignore_detectors: [filecontent]
  - filename: LegalDocML.de/*/schema-extension-fixtures/*.xml
    ignore_detectors: [filecontent]
  - filename: LegalDocML.de/*/samples/*/*.xml
    ignore_detectors: [filecontent]
  - filename: LegalDocML.de/*/samples/*/*.pdf
    ignore_detectors: [filecontent]
  - filename: LegalDocML.de/*/samples/*/*.jpeg
    ignore_detectors: [filecontent]
  - filename: backend/src/test/resources/de/bund/digitalservice/ris/norms/domain/entity/*.xml
    ignore_detectors: [filecontent]
  - filename: backend/src/test/java/de/bund/digitalservice/ris/norms/utils/NodeParserTest.java
    checksum: 37b659328bdbba83886283555c3e3a3892f49218d6d37ac270dff9943e34f44f
  - filename: LegalDocML.de/ris-norms-ldml-schema-extensions
    checksum: 4980a355e26c327ce4ddf8cb227c9d5dde01f9fae8931dc89bf3ac9115c19764
  - filename: backend/gradlew
    checksum: 8b7282ed1fe825d98f73b5909256cbceaf284bed69bf3582d808a4c232943696
